{
	"name": "insult-sword-fighting",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=9.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "wrangler types && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.15.2",
		"@cloudflare/workers-types": "^4.20260501.1",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^25.6.0",
		"better-sqlite3": "^12.9.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"lefthook": "^2.1.6",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@lucide/svelte": "^1.14.0",
		"@tailwindcss/vite": "^4.2.4",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"ulid": "^3.0.2"
	}
}
